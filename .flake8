[flake8]
max-line-length = 88
exclude =
    .git,
    __pycache__,
    build,
    dist,
    docs/source/conf.py,
    old,
    tests/data,
    tests/old,
    examples,
    benchmarks,
    scripts,
    .tox,
    .hypothesis,
    .venv,
    .env,
    .idea,
    .ipynb_checkpoints,
    .pytest_cache,
    .mypy_cache,
    .ropeproject,
    .spyderproject,
    _build,
    _static,
    _templates,
    _themes,
    _venv,
    _env,
    _temp,
    _cache,
    _logs,
    _reports,
    _docs,
    _notes,
    _assets,
    _config,
    _settings,
    _scripts,
    _tools,
    _utils,
    _examples,
    _benchmarks,
    _tests,
    _data,
    _logs,
    _reports,
    _docs,
    _notes,
    _assets,
    _config,
    _settings,
    _scripts,
    _tools,
    _utils,
    _examples,
    _benchmarks,
    _tests,
    _data,
    _logs,
    _reports,
    _docs,
    _notes,
    _assets,
    _
